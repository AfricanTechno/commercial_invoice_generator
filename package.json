{
  "name": "invoicegenerator",
  "version": "1.0.0",
  "description": "A lightweight web app for creating, editing, and printing customs-compliant commercial invoices compatible with DHL, FedEx, UPS, and Aramex. No frameworks, no build tools — just open `index.html` in a browser.",
  "main": "index.js",
  "packageManager": "npm@11.12.1",
  "scripts": {
    "test": "jest --verbose",
    "test:ci": "jest --runInBand --verbose",
    "check": "npm run test:ci"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.[cm]?[jt]sx?$": "babel-jest"
    },
    "transformIgnorePatterns": []
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "jest": "^30.3.0",
    "jsdom": "^29.0.2"
  },
  "overrides": {
    "glob": "^13.0.0",
    "test-exclude": "^8.0.0"
  }
}
